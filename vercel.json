{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/auth/google.js": {
      "maxDuration": 10
    },
    "api/auth/google/callback.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/auth/google/callback", "destination": "/api/auth/google/callback.js" },
    { "source": "/api/auth/google",          "destination": "/api/auth/google.js" },
    { "source": "/api/login-direto",         "destination": "/api/login-direto.js" },
    { "source": "/api/:path*",               "destination": "/api/index.js" },
    { "source": "/(.*)",                     "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
